<?xml version="1.0"?>
<ruleset name="CuratorAI">
    <description>Curator AI WordPress coding standards.</description>

    <file>.</file>
    <exclude-pattern>/vendor/</exclude-pattern>
    <exclude-pattern>/node_modules/</exclude-pattern>
    <exclude-pattern>/tests/</exclude-pattern>
    <exclude-pattern>/assets/build/</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="ps"/>

    <rule ref="WordPress"/>
    <rule ref="WordPress-Extra"/>
    <rule ref="WordPress-Docs"/>

    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="CURAI"/>
                <element value="curai"/>
                <element value="curator_ai"/>
                <element value="Curator_AI"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="curator-ai"/>
            </property>
        </properties>
    </rule>

    <config name="minimum_wp_version" value="7.0"/>
    <config name="testVersion" value="8.1-"/>
</ruleset>
